# Fine-tuned FunctionGemma profile (M58 Phase 4).
# Copy to application-local-finetuned.yml and import your Ollama model first:
#   ollama create functiongemma-medexpertmatch:270m -f Modelfile
#
# Run: --spring.profiles.active=local,local-finetuned
# Rollback: use profile local only (stock functiongemma:270m).

TOOL_CALLING_MODEL: functiongemma-medexpertmatch:270m
TOOL_CALLING_BASE_URL: http://127.0.0.1:11434/v1
TOOL_CALLING_API_KEY: none
TOOL_CALLING_TEMPERATURE: 0.7
TOOL_CALLING_MAX_TOKENS: 4096
